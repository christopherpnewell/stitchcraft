# Server
PORT=3000
NODE_ENV=development

# File handling
UPLOAD_DIR=./uploads
TMP_DIR=./tmp
MAX_FILE_SIZE_MB=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# Processing
PROCESSING_TIMEOUT_MS=30000
MAX_CONCURRENT_JOBS=3

# Security
CSRF_SECRET=change-this-to-a-random-secret

# Google AdSense (optional)
ENABLE_ADS=false
ADSENSE_PUBLISHER_ID=
AD_SLOT_TOP=
AD_SLOT_SIDEBAR=

# Amazon Associates affiliate links (optional)
ENABLE_AFFILIATES=false
AFFILIATE_TAG=

# Admin dashboard (optional — set a password to enable /admin)
ADMIN_PASSWORD=

# Site URL for sitemap and canonical links (no trailing slash)
SITE_URL=https://knitit.app
